<attribute name="Name" >Markdown</attribute>
<attribute name="Sentiment" >-0.4000000099</attribute>
<attribute name="Sentiments" >-0.6;-0.4;0.2;-0.4;-0.4;-0.4;-0.4;-0.4;-0.4;-0.6;-0.6;-0.4;-0.2;-0.6;-0.4</attribute>
<attribute name="SyntaxHighlighting" >Syntax</attribute>
<attribute name="Width" >5</attribute>
<attribute name="Xpos" >0</attribute>
<attribute name="Ypos" >0</attribute>
<text >pattern: (?&lt;!^)//.*
    color: dark red
    
pattern: ^//.*
    size: 10

pattern: ^# .+
    size: 28

pattern: ^## .+
    size: 22

pattern: ^### .+
    size: 18

pattern: (\*\*|__)(.*?)\1
    bold: yes

pattern: (\*|_)(.*?)\1
    italic: yes
    
</text>
</item>
