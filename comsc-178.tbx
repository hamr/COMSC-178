<item ID="1776091065" Creator="Robert Hamrick" proto="Action" >
<attribute name="Created" >2026-04-13T07:37:44-07:00</attribute>
<attribute name="DominantLanguage" >en</attribute>
<attribute name="Height" >2.48</attribute>
<attribute name="Modified" >2026-04-13T07:40:05-07:00</attribute>
<attribute name="Name" >task_state</attribute>
<attribute name="Sentiment" >-0.3500000071</attribute>
<attribute name="Sentiments" >-0.6;-0.4;-0.4;0;-0.2;-0.8;0;-0.4</attribute>
<attribute name="Width" >4</attribute>
<attribute name="Xpos" >4.5</attribute>
<attribute name="Ypos" >0</attribute>
<text >function task_state {
    if ($IsPrototype==true) {
        return;
    }
    if ($Checked==true) {
        $Badge=&quot;check&quot;;
        return;
    }
    $Badge=;
}</text>
