<text >pattern: (?&lt;!^)//.*
    color: dark red
    
pattern: ^//.*
    size: 10

pattern: ^# .+
    size: 28

pattern: ^## .+
    size: 22

pattern: ^### .+
    size: 18

pattern: (\*\*|__)(.*?)\1
    bold: yes

pattern: (\*|_)(.*?)\1
    italic: yes
    
</text>
</item>
